# FinanceFlow - Supabase Credentials Template
# Copy this file to '.env' and fill in your actual Supabase URL and Anon Key.
# DO NOT commit your real '.env' file containing secrets to GitHub.

# Supabase Project URL (Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Public Anonymous Key (Dashboard -> Project Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
